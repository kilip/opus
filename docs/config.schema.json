{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kilip/opus/server/internal/config/config",
  "$ref": "#/$defs/Config",
  "$defs": {
    "Config": {
      "properties": {
        "test_field": {
          "type": "string",
          "description": "A test configuration field"
        },
        "server": {
          "$ref": "#/$defs/Config"
        },
        "database": {
          "$ref": "#/$defs/DatabaseConfig"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "test_field",
        "server",
        "database"
      ]
    },
    "DatabaseConfig": {
      "properties": {
        "driver": {
          "type": "string",
          "enum": [
            "sqlite3",
            "postgres"
          ],
          "description": "Database driver",
          "default": "sqlite3"
        },
        "dsn": {
          "type": "string",
          "description": "Data source name. Inject via OPUS_DATABASE_DSN for production secrets"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "driver",
        "dsn"
      ]
    }
  }
}