# Opus Environment Variables Example
# Copy this file to .env and configure as needed.

# Server Configuration
OPUS_SERVER_ADDRESS=:8080
OPUS_SERVER_DEBUG=false
OPUS_SERVER_BODY_LIMIT=4194304
OPUS_SERVER_PREFORK=false

# Database Configuration
OPUS_DATABASE_DRIVER=sqlite3
# For production, set to a valid DSN:
# OPUS_DATABASE_DSN=postgres://user:password@localhost:5432/opus

# Authentication Configuration
OPUS_AUTH_JWT_SECRET=supersecret
OPUS_AUTH_ACCESS_TOKEN_TTL=15m
OPUS_AUTH_REFRESH_TOKEN_TTL=168h

# OAuth Configuration
# OPUS_AUTH_OAUTH_GOOGLE_CLIENT_ID=
# OPUS_AUTH_OAUTH_GOOGLE_CLIENT_SECRET=
# OPUS_AUTH_OAUTH_GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback
# OPUS_AUTH_OAUTH_GITHUB_CLIENT_ID=
# OPUS_AUTH_OAUTH_GITHUB_CLIENT_SECRET=
# OPUS_AUTH_OAUTH_GITHUB_REDIRECT_URL=http://localhost:8080/auth/github/callback

# Queue Configuration
OPUS_QUEUE_DRIVER=database
# OPUS_QUEUE_DSN=redis://localhost:6379
OPUS_QUEUE_CONCURRENCY=10
OPUS_QUEUE_RETENTION_HOURS=168
